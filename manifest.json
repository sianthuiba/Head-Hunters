{
  "manifest_version": 3,
  "name": "RecruitHub Scout",
  "version": "1.0",
  "description": "Extracts candidate profiles and saves them to your pipeline.",
  "permissions": [
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Scout Sidepanel"
  }
}